# Database
DATABASE_URL=mysql+aiomysql://chat_user:your_password_here@localhost:3306/chat_rooms
AI_DATABASE_URL=postgresql+asyncpg://ai_user:your_password_here@localhost:5432/ai_chat

# Gate
CHAT_GATE_PASSWORD=change-me

# JWT
CHAT_JWT_SECRET=change-me-to-a-random-secret-with-at-least-32-bytes
CHAT_ACCESS_TOKEN_EXPIRE_SECONDS=3600

# AI
AGENT_CORE_ENABLE_LLM_PLANNER=1
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# GitHub Issues proxy
GITHUB_ISSUES_OWNER=Yiyan-Jiang
GITHUB_ISSUES_REPO=Drrr-chatRoom-add-AIChat
# Optional. Use a fine-grained token with read-only public repository access when needed.
GITHUB_TOKEN=
